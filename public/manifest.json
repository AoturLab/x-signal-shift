{
  "manifest_version": 3,
  "name": "X Feedback Loop Rewriter",
  "version": "0.1.0",
  "description": "Re-train X recommendations through automated browsing behavior.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Feedback Loop Rewriter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.global.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.global.js"],
      "run_at": "document_idle"
    }
  ]
}
